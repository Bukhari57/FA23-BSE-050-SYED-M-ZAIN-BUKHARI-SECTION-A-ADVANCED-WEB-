<%- include('../partials/header') %>
<h1>Menu Items <a href="/menuitems/new" class="btn btn-primary float-end">Add New</a></h1>
<br />
<div class="row" id="menuContainer">
  <% items.forEach(item => { %>
    <div class="col-md-4 mb-4 menu-card" data-name="<%= item.name %>" data-category="<%= item.category || '' %>">
      <div class="card h-100 shadow-sm animate__animated">
        <div class="position-relative">
          <img src="<%= item.imageUrl || ('https://via.placeholder.com/600x400?text=' + encodeURIComponent(item.name)) %>" class="card-img-top" alt="<%= item.name %>">
          <% if(item.category){ %>
            <span class="category-badge"><%= item.category %></span>
          <% } %>
          <div class="price-badge">$<%= item.price %></div>
        </div>
        <div class="card-body">
          <h5 class="card-title">
            <% if(item.iconClass){ %><i class="<%= item.iconClass %> me-2"></i><% } %>
            <%= item.name %>
          </h5>
          <p class="card-text text-muted small"><%= item.description %></p>
          <div class="d-flex justify-content-between align-items-center mt-3">
            <div>
              <span class="rating"><i class="fas fa-star"></i> 4.7</span>
              <span class="text-muted small ms-2">• 120+ reviews</span>
            </div>
            <div>
              <button class="btn btn-gradient btn-sm add-to-cart" data-id="<%= item.id %>" data-name="<%= item.name %>" data-price="<%= item.price %>" data-image="<%= item.imageUrl %>">Add</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% }) %>
</div>
<%- include('../partials/footer') %>