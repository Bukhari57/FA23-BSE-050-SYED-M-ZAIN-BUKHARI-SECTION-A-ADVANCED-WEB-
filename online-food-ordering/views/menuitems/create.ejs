<%- include('../partials/header') %>
<h1>Add Menu Item</h1>
<form action="/menuitems" method="POST">
  <div class="form-floating mb-3">
    <input class="form-control" id="name" name="name" placeholder="Name" required>
    <label for="name">Name</label>
  </div>
  <div class="form-floating mb-3">
    <input class="form-control" id="description" name="description" placeholder="Description">
    <label for="description">Description</label>
  </div>
  <div class="form-floating mb-3">
    <input type="number" step="0.01" class="form-control" id="price" name="price" placeholder="Price" required>
    <label for="price">Price</label>
  </div>
  <div class="form-floating mb-3">
    <input class="form-control" id="category" name="category" placeholder="Category">
    <label for="category">Category</label>
  </div>
  <div class="mb-3">
    <label class="form-label">Icon class (FontAwesome)</label>
    <input class="form-control" name="iconClass" placeholder="fa-pizza-slice">
  </div>
  <div class="mb-3">
    <label class="form-label">Image URL</label>
    <input class="form-control" name="imageUrl" placeholder="http://...">
  </div>
  <button class="btn btn-success btn-gradient">Save</button>
  <a href="/menuitems" class="btn btn-secondary">Cancel</a>
</form>
<%- include('../partials/footer') %>