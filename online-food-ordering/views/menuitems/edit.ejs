<%- include('../partials/header') %>
<h1>Edit Menu Item</h1>
<form action="/menuitems/<%= item.id %>?_method=PUT" method="POST">
  <div class="form-floating mb-3">
    <input class="form-control" id="name" name="name" value="<%= item.name %>" placeholder="Name" required>
    <label for="name">Name</label>
  </div>
  <div class="form-floating mb-3">
    <input class="form-control" id="description" name="description" value="<%= item.description %>" placeholder="Description">
    <label for="description">Description</label>
  </div>
  <div class="form-floating mb-3">
    <input type="number" step="0.01" class="form-control" id="price" name="price" value="<%= item.price %>" placeholder="Price" required>
    <label for="price">Price</label>
  </div>
  <div class="form-floating mb-3">
    <input class="form-control" id="category" name="category" value="<%= item.category %>" placeholder="Category">
    <label for="category">Category</label>
  </div>
  <div class="mb-3">
    <label class="form-label">Icon class (FontAwesome)</label>
    <input class="form-control" name="iconClass" value="<%= item.iconClass %>" placeholder="fa-pizza-slice">
  </div>
  <div class="mb-3">
    <label class="form-label">Image URL</label>
    <input class="form-control" name="imageUrl" value="<%= item.imageUrl %>" placeholder="http://...">
  </div>
  <button class="btn btn-success btn-gradient">Update</button>
  <a href="/menuitems" class="btn btn-secondary">Cancel</a>
</form>
<%- include('../partials/footer') %>
