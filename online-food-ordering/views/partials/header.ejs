<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Online Food Ordering</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link rel="stylesheet" href="/css/style.css">
<!-- Premium UI -->
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/ui-modern.css">
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4 sticky-top modern-navbar">
  <div class="container-fluid">
    <a class="navbar-brand" href="/menuitems">Food Order</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNav">
      <ul class="navbar-nav me-auto">
        <li class="nav-item"><a class="nav-link" href="/menuitems">Menu Items</a></li>
        <li class="nav-item"><a class="nav-link" href="/orders">Orders</a></li>
      </ul>
      <form class="d-flex ms-auto me-3" role="search">
        <input id="searchInput" class="form-control form-control-sm" type="search" placeholder="Search" aria-label="Search">
      </form>
      <button class="btn btn-outline-light position-relative me-2" id="cartButton" data-bs-toggle="modal" data-bs-target="#cartModal">
        <i class="fas fa-shopping-cart"></i>
        <span class="badge bg-danger position-absolute top-0 start-100 translate-middle" id="cartCount">0</span>
      </button>
      <div class="form-check form-switch text-light">
        <input class="form-check-input" type="checkbox" id="darkModeToggle" data-theme-toggle>
        <label class="form-check-label" for="darkModeToggle">Dark</label>
      </div>
    </div>
  </div>
</nav>

<!-- Cart modal -->
<div class="modal fade" id="cartModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Cart</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body" id="cartModalBody"></div>
      <div class="modal-footer">
        <a href="/orders/new" class="btn btn-primary">Checkout</a>
      </div>
    </div>
  </div>
</div>

<!-- Premium Hero -->
<section class="hero py-5 text-white d-flex align-items-center">
  <div class="container text-center">
    <h1 class="display-5 fw-bold hero-title">Delicious Food — Delivered Fast</h1>
    <p class="lead hero-sub">Premium curated menu, lightning delivery, and delightful experiences.</p>
    <a href="/menuitems" class="btn btn-lg btn-gradient hero-cta me-3">Explore Menu</a>
    <a href="/orders" class="btn btn-outline-light btn-lg">View Orders</a>
  </div>
</section>

<div class="container">