<%- include('../partials/header') %>
<h1>Orders <a href="/orders/new" class="btn btn-primary float-end">New Order</a></h1>
<table class="table table-striped">
  <thead>
    <tr>
      <th>#</th>
      <th>Customer</th>
      <th>Items</th>
      <th>Total</th>
      <th>Status</th>
      <th>Date</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% orders.forEach(order => { %>
      <tr class="animate__animated animate__fadeInUp">
        <td><%= order.id %></td>
        <td><%= order.customerName %></td>
        <td><%= order.items.length %></td>
        <td>$<%= order.totalPrice.toFixed(2) %></td>
        <td><%= order.status %></td>
        <td><%= order.createdAt.toLocaleString() %></td>
        <td>
          <a href="/orders/<%= order.id %>/edit" class="btn btn-warning btn-sm">Edit</a>
          <a href="/orders/<%= order.id %>" class="btn btn-info btn-sm">View</a>
          <form action="/orders/<%= order.id %>?_method=DELETE" method="POST" class="d-inline">
            <button class="btn btn-danger btn-sm">Delete</button>
          </form>
        </td>
      </tr>
    <% }); %>
  </tbody>
</table>
<%- include('../partials/footer') %>