<%- include('partials/header') %>

  <main class="py-5">
    <header class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h1 class="mb-0">Discover our Menu</h1>
        <p class="muted">Fresh, fast and delicious — curated for you.</p>
      </div>
      <div class="d-flex gap-2 align-items-center">
        <div class="input-group">
          <input class="form-control" placeholder="Search dishes...">
          <button class="btn btn-outline-secondary">Search</button>
        </div>
      </div>
    </header>

    <section id="menu" class="menu-grid mb-5">
      <!-- Dummy items (use your DB in production) -->
      <article class="food-card">
        <div class="food-media"><img src="/images/placeholder_plate.svg" alt="Dish"></div>
        <div class="mt-3">
          <div class="d-flex justify-content-between align-items-start">
            <div>
              <div class="food-title">Margherita Pizza</div>
              <div class="food-desc">Classic tomato & mozzarella</div>
            </div>
            <div class="text-end">
              <div class="price-badge">$9.99</div>
            </div>
          </div>
          <div class="card-footer">
            <div class="d-flex align-items-center">
              <div class="rating"><i class="fas fa-star"></i> 4.7</div>
              <div class="badge-cat">Vegetarian</div>
            </div>
            <div>
              <button class="btn-add" data-add-to-cart data-id="1" data-name="Margherita Pizza" data-price="9.99" data-img="/images/placeholder_plate.svg">Add to Cart</button>
            </div>
          </div>
        </div>
      </article>

      <article class="food-card">
        <div class="food-media"><img src="/images/placeholder_bowl.svg" alt="Dish"></div>
        <div class="mt-3">
          <div class="d-flex justify-content-between align-items-start">
            <div>
              <div class="food-title">Spicy Ramen</div>
              <div class="food-desc">Noodles in rich broth</div>
            </div>
            <div class="text-end">
              <div class="price-badge">$7.50</div>
            </div>
          </div>
          <div class="card-footer">
            <div class="d-flex align-items-center">
              <div class="rating"><i class="fas fa-star"></i> 4.6</div>
              <div class="badge-cat">Noodles</div>
            </div>
            <div>
              <button class="btn-add" data-add-to-cart data-id="2" data-name="Spicy Ramen" data-price="7.5" data-img="/images/placeholder_bowl.svg">Add to Cart</button>
            </div>
          </div>
        </div>
      </article>

      <article class="food-card">
        <div class="food-media"><img src="/images/placeholder_burger.svg" alt="Dish"></div>
        <div class="mt-3">
          <div class="d-flex justify-content-between align-items-start">
            <div>
              <div class="food-title">Smash Burger</div>
              <div class="food-desc">Juicy beef patty with cheese</div>
            </div>
            <div class="text-end">
              <div class="price-badge">$8.49</div>
            </div>
          </div>
          <div class="card-footer">
            <div class="d-flex align-items-center">
              <div class="rating"><i class="fas fa-star"></i> 4.8</div>
              <div class="badge-cat">Burgers</div>
            </div>
            <div>
              <button class="btn-add" data-add-to-cart data-id="3" data-name="Smash Burger" data-price="8.49" data-img="/images/placeholder_burger.svg">Add to Cart</button>
            </div>
          </div>
        </div>
      </article>

      <article class="food-card">
        <div class="food-media"><img src="/images/placeholder_dessert.svg" alt="Dish"></div>
        <div class="mt-3">
          <div class="d-flex justify-content-between align-items-start">
            <div>
              <div class="food-title">Chocolate Brownie</div>
              <div class="food-desc">Rich fudgy brownie</div>
            </div>
            <div class="text-end">
              <div class="price-badge">$4.25</div>
            </div>
          </div>
          <div class="card-footer">
            <div class="d-flex align-items-center">
              <div class="rating"><i class="fas fa-star"></i> 4.9</div>
              <div class="badge-cat">Dessert</div>
            </div>
            <div>
              <button class="btn-add" data-add-to-cart data-id="4" data-name="Chocolate Brownie" data-price="4.25" data-img="/images/placeholder_dessert.svg">Add to Cart</button>
            </div>
          </div>
        </div>
      </article>

    </section>

    <!-- Footer area will be included by partial -->
  </main>

  <!-- Floating Cart Button and Panel -->
  <div class="floating-cart">
    <button id="floatingCartBtn" class="cart-btn"><i class="fas fa-shopping-cart"></i> <span id="cartCount">0</span></button>
  </div>
  <aside id="cartPanel" class="cart-panel">
    <h5>Your Cart</h5>
    <div id="cartItems" class="cart-items"></div>
    <div class="d-flex justify-content-between align-items-center mt-3"><div class="muted">Total</div><div id="cartTotal">$0.00</div></div>
    <form id="checkoutForm" class="mt-3">
      <input class="form-control mb-2" name="name" placeholder="Full name" required>
      <input class="form-control mb-2" name="email" placeholder="Email" required>
      <button class="btn btn-primary w-100" type="submit" style="background:linear-gradient(90deg,#7c5cff,#00c2a8);border:none">Checkout</button>
    </form>
  </aside>

  <div id="uiToast" class="toast-fab">Added</div>

<%- include('partials/footer') %>
